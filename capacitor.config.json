{
  "appId": "uz.chibu.app",
  "appName": "CHIBU",
  "webDir": "mobile-shell",
  "server": {
    "url": "https://animestore.uz",
    "cleartext": false,
    "allowNavigation": [
      "animestore.uz"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "webContentsDebuggingEnabled": false,
    "buildOptions": {
      "keystorePath": "release.keystore",
      "keystoreAlias": "chibu"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0f172a",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    }
  }
}
